<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0E1A"
        android:padding="12dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 Debug Console — مراقبة التشغيل"
            android:textColor="#4F8EF7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="العمليات والأخطاء"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textAlignment="center"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Console Output -->
    <ScrollView
        android:id="@+id/scroll_console"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#050709"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_console"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textColor="#00FF00"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.2"
            android:text="جاري انتظار السجلات..."/>
    </ScrollView>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0A0E1A"
        android:padding="10dp"
        android:gravity="center"
        android:spacing="6dp"
        android:elevation="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_logs"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="مسح"
            android:textSize="11sp"
            android:backgroundTint="#FFA500"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="6dp"
            android:layout_marginEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_logs"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="نسخ"
            android:textSize="11sp"
            android:backgroundTint="#4F8EF7"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="6dp"
            android:layout_marginEnd="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_console"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="أغلق"
            android:textSize="11sp"
            android:backgroundTint="#EF4444"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="6dp"/>
    </LinearLayout>

</LinearLayout>
