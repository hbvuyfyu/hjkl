<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0E1A"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="شروط الاستخدام والخصوصية"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ اقرأ بعناية قبل الاستخدام"
            android:textColor="#FFA500"
            android:textSize="12sp"
            android:textAlignment="center"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- Scrollable Terms Content -->
    <ScrollView
        android:id="@+id/scroll_terms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_terms_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.4"
            android:fontFamily="monospace"
            android:text="Loading..."/>
    </ScrollView>

    <!-- Checkbox Agreement -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#0A0E1A"
        android:padding="12dp"
        android:elevation="2dp">

        <CheckBox
            android:id="@+id/cb_agree_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#4F8EF7"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="أوافق على جميع الشروط والسياسات وأقبل المسؤولية الكاملة"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#050709"
        android:padding="12dp"
        android:gravity="center"
        android:elevation="4dp"
        android:spacing="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reject_terms"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="رفض وخروج"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="8dp"
            app:strokeColor="#EF4444"
            app:strokeWidth="2dp"
            android:layout_marginEnd="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_accept_terms"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="✓ أوافق وأدخل"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#22C55E"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="8dp"
            android:layout_marginStart="6dp"/>
    </LinearLayout>

</LinearLayout>
